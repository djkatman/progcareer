---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = '未経験からエンジニアへ。プログラミングスクール比較・IT転職エージェント比較を一気通貫でサポートするメディア「ProgCareer（プログキャリア）」',
  canonical = Astro.url.href,
  ogImage = '/images/og-default.svg',
} = Astro.props;

const siteName = 'ProgCareer（プログキャリア）';
const fullTitle = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- OGP -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={`https://progcareer.com${ogImage}`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://progcareer.com${ogImage}`} />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- PR表記バナー -->
  <div class="pr-banner">
    <p>本サイトはアフィリエイト広告（プログラミングスクール・転職サービスの紹介料）を含みます。</p>
  </div>

  <!-- ヘッダー -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32" aria-hidden="true">
          <rect width="64" height="64" rx="12" fill="#0F172A"/>
          <polyline points="8,48 24,32 36,40 56,16" fill="none" stroke="#3B82F6" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="56" cy="16" r="5" fill="#F59E0B"/>
        </svg>
        <span class="logo-text">
          <span class="logo-main">ProgCareer</span>
          <span class="logo-sub">未経験IT転職ナビ</span>
        </span>
      </a>

      <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="site-nav" id="site-nav">
        <ul>
          <li><a href="/">トップ</a></li>
          <li><a href="/school-ranking/">スクール比較</a></li>
          <li><a href="/agent-ranking/">転職エージェント比較</a></li>
          <li><a href="/beginner-guide/">未経験ガイド</a></li>
          <li><a href="/faq/">よくある質問</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- メインコンテンツ -->
  <main>
    <slot />
  </main>

  <!-- フッター -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-col footer-brand">
        <div class="footer-logo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="28" height="28" aria-hidden="true">
            <rect width="64" height="64" rx="12" fill="#1E293B"/>
            <polyline points="8,48 24,32 36,40 56,16" fill="none" stroke="#3B82F6" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="56" cy="16" r="5" fill="#F59E0B"/>
          </svg>
          <span>ProgCareer</span>
        </div>
        <p class="footer-brand-desc">未経験からITエンジニアへの転職を目指す人のための比較・情報メディア。スクール選び・エージェント選びをトータルサポートします。</p>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">コンテンツ</p>
        <nav class="footer-nav">
          <ul>
            <li><a href="/school-ranking/">スクールランキング</a></li>
            <li><a href="/agent-ranking/">エージェントランキング</a></li>
            <li><a href="/beginner-guide/">未経験ガイド</a></li>
            <li><a href="/faq/">よくある質問</a></li>
          </ul>
        </nav>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">サイト情報</p>
        <nav class="footer-nav">
          <ul>
            <li><a href="/about/">運営者情報</a></li>
            <li><a href="/privacy-policy/">プライバシーポリシー</a></li>
            <li><a href="/disclaimer/">免責事項</a></li>
          </ul>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="copyright">&copy; 2026 ProgCareer. All Rights Reserved.</p>
    </div>
  </footer>

  <script>
    const hamburger = document.getElementById('hamburger');
    const nav = document.getElementById('site-nav');
    hamburger?.addEventListener('click', () => {
      const isOpen = nav?.classList.toggle('is-open');
      hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  </script>
</body>
</html>

<style is:global>
  /* リセット＋デザイントークン */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-primary: #0F172A;
    --color-primary-mid: #1E40AF;
    --color-accent: #3B82F6;
    --color-accent-vivid: #60A5FA;
    --color-highlight: #F59E0B;
    --color-bg: #F8FAFC;
    --color-surface: #FFFFFF;
    --color-border: #E2E8F0;
    --color-text: #0F172A;
    --color-text-muted: #64748B;
    --font-base: 'Noto Sans JP', sans-serif;
    --max-width: 1100px;
    --radius: 8px;
  }

  html { font-size: 16px; scroll-behavior: smooth; }
  body {
    font-family: var(--font-base);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
  }
  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* PR表記バナー */
  .pr-banner {
    background: #fef9c3;
    border-bottom: 1px solid #fde68a;
    text-align: center;
    padding: 6px 16px;
    font-size: 0.75rem;
    color: #92400e;
  }

  /* ヘッダー */
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    line-height: 1.2;
  }
  .logo-icon { flex-shrink: 0; }
  .logo-text {
    display: flex;
    flex-direction: column;
  }
  .logo-main {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.03em;
  }
  .logo-sub {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }
  .site-nav ul {
    display: flex;
    gap: 28px;
  }
  .site-nav a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .site-nav a:hover { color: var(--color-accent); }

  /* ハンバーガー */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    min-height: 44px;
    min-width: 44px;
    align-items: center;
    justify-content: center;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
  }

  /* フッター */
  .site-footer {
    background: var(--color-primary);
    color: #94A3B8;
    padding: 60px 20px 0;
    margin-top: 80px;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid #1E293B;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }
  .footer-brand-desc {
    font-size: 0.82rem;
    line-height: 1.8;
    color: #64748B;
  }
  .footer-col-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: #64748B;
    transition: color 0.2s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .footer-nav a:hover { color: #fff; }
  .footer-bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 20px 0;
  }
  .copyright {
    font-size: 0.78rem;
    color: #334155;
  }

  /* レスポンシブ */
  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .site-nav {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 16px 20px;
    }
    .site-nav.is-open { display: block; }
    .site-nav ul { flex-direction: column; gap: 4px; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
