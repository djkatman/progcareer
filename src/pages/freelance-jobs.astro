---
import Layout from '../layouts/Layout.astro';
import { freelance, getUrl } from '../data/affiliates';

const services = [
  {
    rank: 1,
    id: 'freelance-board',
    name: 'フリーランスボード',
    tagline: '案件数No.1級・スキルマッチングで最適案件を自動提案',
    target: '経験1年以上のフリーランスエンジニア',
    features: ['案件数が業界最多水準', 'スキルマッチング機能', '単価交渉サポート', 'リモート案件が豊富'],
    pros: '掲載案件数が多く、幅広いスキルセットに対応。スキルを登録するだけで案件が自動マッチングされる。',
    cons: '未経験・実務経験なしには対応案件が少ない。',
    recommended: '実務経験1年以上・独立を検討しているエンジニア',
    highlight: true,
    badge: '案件数最多水準',
    fee: '無料',
    condition: '無料登録',
  },
  {
    rank: 2,
    id: 'it-kyujin',
    name: 'IT求人ナビ フリーランス',
    tagline: 'IT特化・フリーランス案件に強い専門サービス',
    target: 'フリーランス転向を検討しているITエンジニア',
    features: ['IT特化の案件のみ掲載', 'フリーランス専門サポート', '単価目安が明示', '契約・請求書管理サポート'],
    pros: 'IT案件に特化しているため求人の質が高い。契約まわりのサポートが充実しており、初めてのフリーランスでも安心。',
    cons: 'IT以外のジャンルには非対応。',
    recommended: '初めてフリーランスに挑戦するITエンジニア',
    highlight: false,
    badge: 'IT特化',
    fee: '無料',
    condition: '無料登録',
  },
  {
    rank: 3,
    id: 'selwork',
    name: 'セルワークITフリーランス',
    tagline: 'エンジニア向けフリーランス案件・高単価に強い',
    target: '高単価案件を狙うシニアエンジニア',
    features: ['高単価案件が多い', 'エンジニア専門担当者', '週3〜4日案件あり', '稼働条件が柔軟'],
    pros: '高単価・週3〜4日などの柔軟な稼働条件の案件が多い。副業としてフリーランス案件を受けたい方にも対応。',
    cons: 'ジュニア層向けの案件は少なめ。',
    recommended: '副業・ダブルワークでフリーランス案件を探している方',
    highlight: false,
    badge: '高単価・柔軟稼働',
    fee: '無料',
    condition: '無料登録',
  },
  {
    rank: 4,
    id: 'freelance-concierge',
    name: 'フリコン',
    tagline: 'フリーランス向けコンシェルジュ型案件紹介サービス',
    target: 'フリーランス独立に不安を感じているエンジニア',
    features: ['専任コンシェルジュが担当', '案件提案から契約まで伴走', '税務・確定申告サポート連携', '独立相談も対応'],
    pros: '案件紹介だけでなく独立に関する相談にも対応。はじめてのフリーランスでも丁寧にサポートしてもらえる。',
    cons: 'コンシェルジュ対応のため掲載案件数は大手に劣る場合がある。',
    recommended: 'フリーランス独立を検討中・はじめて案件を探す方',
    highlight: false,
    badge: 'コンシェルジュ型',
    fee: '無料',
    condition: '無料相談',
  },
];

const comparisons = [
  { label: '案件数を重視したい', services: ['フリーランスボード', 'IT求人ナビ フリーランス'], reason: '掲載数が多い2サービスに登録することで、より多くの選択肢から最適な案件を選べます。' },
  { label: '初めてのフリーランス', services: ['IT求人ナビ フリーランス', 'フリコン'], reason: 'サポートが手厚い2サービスの組み合わせ。契約・確定申告まで相談できて安心です。' },
  { label: '高単価・副業案件を探したい', services: ['フリーランスボード', 'セルワークITフリーランス'], reason: '高単価案件が豊富な2サービスで、条件の良い案件を比較検討できます。' },
];

const faqs = [
  { q: 'フリーランス案件検索サービスは無料で使えますか？', a: 'はい、本記事で紹介しているサービスはすべて求職者（フリーランス）側の利用は無料です。サービス側は企業（クライアント）からの手数料で収益を得ています。' },
  { q: '未経験からフリーランスになれますか？', a: 'フリーランス案件の多くは実務経験を求めます。まずはプログラミングスクールや転職を通じて1〜2年の実務経験を積み、その後フリーランスに転向するルートが現実的です。' },
  { q: '複数のサービスに登録してもいいですか？', a: '問題ありません。2〜3サービスに並行登録して案件を比較することが一般的です。サービスによって掲載案件が異なるため、登録数が多いほど選択肢が広がります。' },
  { q: 'フリーランスエンジニアの平均月収はいくらですか？', a: '経験やスキルにより大きく異なりますが、ITエンジニアのフリーランスは月50〜100万円程度が一般的な水準です。高単価スキル（AWS・機械学習など）を持つ方はさらに高収入も可能です。' },
  { q: '正社員からフリーランスに転向する際の注意点は？', a: '社会保険・年金の手続き変更、確定申告、案件の空白期間リスクなどがあります。フリコンなどコンシェルジュ型サービスに相談しながら、計画的に準備を進めることをおすすめします。' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      name: 'フリーランス案件検索サービスおすすめ比較2026',
      itemListElement: services.map((s, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: s.name,
        description: s.tagline,
      })),
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

const badgeColors: Record<number, string> = { 1: '#F59E0B', 2: '#94A3B8', 3: '#D97706' };

const affiliateUrls: Record<string, string> = {};
for (const item of freelance) {
  affiliateUrls[item.id] = item.affiliate_url;
}
---

<Layout
  title="フリーランス案件検索サービスおすすめ比較【2026年最新】エンジニア向け"
  description="フリーランスエンジニア向けの案件検索・マッチングサービスを徹底比較。案件数・単価・サポート内容を総合評価したランキングと選び方を解説します。"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-wrapper">
    <div class="container">

      <p class="pr-note">※本ページはアフィリエイト広告を含みます。掲載情報は編集部が独自に調査・評価しています。</p>

      <h1 class="page-title">フリーランス案件検索サービスおすすめ比較【2026年最新】</h1>
      <p class="page-lead">エンジニアのフリーランス転向・副業案件探しに役立つサービスを案件数・単価・サポート体制で徹底比較しました。</p>

      <!-- 比較テーブル -->
      <section class="section">
        <h2 class="section-title">サービス比較一覧</h2>
        <div class="table-scroll">
          <table class="compare-table">
            <thead>
              <tr>
                <th>サービス名</th>
                <th>特徴</th>
                <th>向いている人</th>
                <th>料金</th>
              </tr>
            </thead>
            <tbody>
              {services.map((s) => (
                <tr class={s.highlight ? 'row-highlight' : ''}>
                  <td class="td-name">{s.name}</td>
                  <td class="td-badge">{s.badge}</td>
                  <td class="td-target">{s.recommended}</td>
                  <td class="td-fee">{s.fee}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- 個別カード -->
      <section class="section">
        <h2 class="section-title">おすすめサービス詳細</h2>
        <div class="card-list">
          {services.map((s) => (
            <div class={`service-card ${s.highlight ? 'service-card--highlight' : ''}`}>
              <div class="card-badges">
                <span class="rank-badge" style={`background: ${badgeColors[s.rank] ?? '#6B7280'}`}>第{s.rank}位</span>
                <span class="tag-badge">{s.badge}</span>
              </div>
              <h3 class="card-name">{s.name}</h3>
              <p class="card-tagline">{s.tagline}</p>
              <ul class="feature-list">
                {s.features.map((f) => (
                  <li><span class="check">✓</span>{f}</li>
                ))}
              </ul>
              <div class="pros-cons">
                <div class="pros">
                  <p class="pros-label">メリット</p>
                  <p>{s.pros}</p>
                </div>
                <div class="cons">
                  <p class="cons-label">デメリット</p>
                  <p>{s.cons}</p>
                </div>
              </div>
              <p class="card-target">こんな人におすすめ: {s.recommended}</p>
              <a
                href={affiliateUrls[s.id]}
                rel="sponsored"
                target="_blank"
                class={`cta-btn ${s.highlight ? 'cta-btn--highlight' : ''}`}
              >
                {s.name}の公式サイトを見る（{s.condition}）
              </a>
            </div>
          ))}
        </div>
      </section>

      <!-- 目的別おすすめ組み合わせ -->
      <section class="section">
        <h2 class="section-title">目的別おすすめ登録パターン</h2>
        <div class="pattern-list">
          {comparisons.map((c) => (
            <div class="pattern-card">
              <p class="pattern-label">🎯 {c.label}</p>
              <p class="pattern-services">{c.services.join(' ＋ ')}</p>
              <p class="pattern-reason">{c.reason}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="section">
        <h2 class="section-title">よくある質問</h2>
        <div class="faq-list">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary class="faq-q">{f.q}</summary>
              <p class="faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- 内部リンク -->
      <section class="related-links">
        <h2 class="related-title">関連記事</h2>
        <ul>
          <li><a href="/school-ranking/">→ プログラミングスクール比較ランキング【2026年最新】</a></li>
          <li><a href="/agent-ranking/">→ IT転職エージェントおすすめランキング【2026年最新】</a></li>
          <li><a href="/blog/engineer-career-change-roadmap/">→ 未経験からIT転職を成功させるロードマップ</a></li>
        </ul>
      </section>

    </div>
  </div>
</Layout>

<style>
  .page-wrapper {
    padding: 40px 0 80px;
  }

  .pr-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background: #fef9c3;
    border: 1px solid #fde68a;
    border-radius: var(--radius);
    padding: 8px 12px;
    margin-bottom: 24px;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .page-lead {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 40px;
  }

  .section {
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-accent);
  }

  /* 比較テーブル */
  .table-scroll {
    overflow-x: auto;
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .compare-table th {
    background: #F1F5F9;
    border: 1px solid var(--color-border);
    padding: 10px 12px;
    text-align: left;
    font-weight: 700;
    color: var(--color-text);
  }

  .compare-table td {
    border: 1px solid var(--color-border);
    padding: 10px 12px;
    color: var(--color-text-muted);
    vertical-align: middle;
  }

  .compare-table .row-highlight {
    background: #FFFBEB;
  }

  .td-name { font-weight: 600; color: var(--color-text); }
  .td-fee { text-align: center; color: #16A34A; font-weight: 600; }

  /* カードリスト */
  .card-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 24px;
  }

  .service-card--highlight {
    border-color: #F59E0B;
    background: #FFFBEB;
  }

  .card-badges {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }

  .rank-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .tag-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    background: #DBEAFE;
    color: #1D4ED8;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .card-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .card-tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .feature-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-bottom: 16px;
  }

  .feature-list li {
    font-size: 0.8rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .check {
    color: #16A34A;
    font-weight: 700;
  }

  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .pros {
    background: #F0FDF4;
    border-radius: var(--radius);
    padding: 12px;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  .pros-label {
    font-weight: 700;
    color: #15803D;
    margin-bottom: 4px;
  }

  .cons {
    background: #FFF1F2;
    border-radius: var(--radius);
    padding: 12px;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  .cons-label {
    font-weight: 700;
    color: #BE123C;
    margin-bottom: 4px;
  }

  .card-target {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .cta-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px 24px;
    border-radius: var(--radius);
    font-size: 0.95rem;
    font-weight: 700;
    background: var(--color-accent);
    color: #fff;
    transition: background 0.2s, opacity 0.2s;
    cursor: pointer;
  }

  .cta-btn:hover {
    background: var(--color-primary-mid);
  }

  .cta-btn--highlight {
    background: #F59E0B;
  }

  .cta-btn--highlight:hover {
    background: #D97706;
  }

  /* 目的別パターン */
  .pattern-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pattern-card {
    background: #EFF6FF;
    border: 1px solid #BFDBFE;
    border-radius: var(--radius);
    padding: 16px 20px;
  }

  .pattern-label {
    font-weight: 700;
    color: #1D4ED8;
    margin-bottom: 4px;
  }

  .pattern-services {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
    font-size: 0.9rem;
  }

  .pattern-reason {
    font-size: 0.825rem;
    color: var(--color-text-muted);
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }

  .faq-q {
    padding: 14px 16px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::before {
    content: 'Q. ';
    color: var(--color-accent);
    font-weight: 700;
  }

  .faq-a {
    padding: 0 16px 14px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  /* 関連記事 */
  .related-links {
    background: #F8FAFC;
    border-radius: var(--radius);
    padding: 20px 24px;
  }

  .related-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .related-links ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .related-links a {
    font-size: 0.875rem;
    color: var(--color-accent);
    transition: opacity 0.2s;
  }

  .related-links a:hover {
    opacity: 0.7;
    text-decoration: underline;
  }

  /* レスポンシブ */
  @media (max-width: 640px) {
    .page-title { font-size: 1.3rem; }
    .feature-list { grid-template-columns: 1fr; }
    .pros-cons { grid-template-columns: 1fr; }
  }
</style>
