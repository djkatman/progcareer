---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = '未経験からエンジニアへ。プログラミングスクール比較・IT転職エージェント比較を一気通貫でサポートするメディア「ProgCareer（プログキャリア）」',
  canonical = Astro.url.href,
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const siteName = 'ProgCareer（プログキャリア）';
const fullTitle = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- OGP -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={`https://progcareer.com${ogImage}`} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://progcareer.com${ogImage}`} />

  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- PR表記バナー -->
  <div class="pr-banner">
    <p>本サイトはアフィリエイト広告（プログラミングスクール・転職サービスの紹介料）を含みます。</p>
  </div>

  <!-- ヘッダー -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">ProgCareer</a>

      <button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="site-nav" id="site-nav">
        <ul>
          <li><a href="/">トップ</a></li>
          <li><a href="/school-ranking/">スクール比較</a></li>
          <li><a href="/agent-ranking/">転職エージェント比較</a></li>
          <li><a href="/beginner-guide/">未経験ガイド</a></li>
          <li><a href="/faq/">よくある質問</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- メインコンテンツ -->
  <main>
    <slot />
  </main>

  <!-- フッター -->
  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-logo">ProgCareer（プログキャリア）</p>
      <nav class="footer-nav">
        <ul>
          <li><a href="/privacy-policy/">プライバシーポリシー</a></li>
          <li><a href="/disclaimer/">免責事項</a></li>
          <li><a href="/about/">運営者情報</a></li>
        </ul>
      </nav>
      <p class="copyright">&copy; 2026 ProgCareer. All Rights Reserved.</p>
    </div>
  </footer>

  <script>
    const hamburger = document.getElementById('hamburger');
    const nav = document.getElementById('site-nav');
    hamburger?.addEventListener('click', () => {
      const isOpen = nav?.classList.toggle('is-open');
      hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  </script>
</body>
</html>

<style is:global>
  /* リセット＋デザイントークン */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-primary: #1E40AF;
    --color-primary-dark: #1e3a8a;
    --color-accent: #F59E0B;
    --color-accent-dark: #d97706;
    --color-bg: #F8FAFC;
    --color-text: #1e293b;
    --color-text-muted: #64748b;
    --color-border: #e2e8f0;
    --font-base: 'Noto Sans JP', sans-serif;
    --max-width: 1100px;
    --radius: 8px;
  }

  html { font-size: 16px; scroll-behavior: smooth; }
  body {
    font-family: var(--font-base);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
  }
  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  /* PR表記バナー */
  .pr-banner {
    background: #fef9c3;
    border-bottom: 1px solid #fde68a;
    text-align: center;
    padding: 6px 16px;
    font-size: 0.75rem;
    color: #92400e;
  }

  /* ヘッダー */
  .site-header {
    background: #fff;
    border-bottom: 2px solid var(--color-primary);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.03em;
  }
  .site-nav ul {
    display: flex;
    gap: 28px;
  }
  .site-nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color 0.2s;
  }
  .site-nav a:hover { color: var(--color-primary); }

  /* ハンバーガー */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
  }

  /* フッター */
  .site-footer {
    background: var(--color-primary-dark);
    color: #cbd5e1;
    padding: 48px 20px 24px;
    margin-top: 80px;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }
  .footer-logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
  }
  .footer-nav ul {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: #94a3b8;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: #fff; }
  .copyright {
    font-size: 0.8rem;
    color: #64748b;
  }

  /* レスポンシブ */
  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .site-nav {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 2px solid var(--color-primary);
      padding: 16px 20px;
    }
    .site-nav.is-open { display: block; }
    .site-nav ul { flex-direction: column; gap: 16px; }
  }
</style>
